# Database Configuration
DB_HOST=127.0.0.1
DB_PORT=5432
# Для локальной PostgreSQL:
# DB_NAME=carvix
# DB_USER=postgres
# DB_PASSWORD=your_password
# DB_HOST=localhost
# DB_PORT=5432

# Для облачных БД (Neon, Supabase, etc.):
DATABASE_URL=postgresql://username:password@host/database?sslmode=require

# Принудительное включение SSL (для локальных БД с SSL)
PGSSL=false
